# AddressIQ Android SDK — local development overrides.
#
# Two ways to supply these; either works, the environment wins:
#
#   1. local.properties (gitignored, already used by the Android SDK for sdk.dir):
#        echo 'ADDRESSIQ_DEV_API_URL=http://192.168.1.5:4000' >> local.properties
#
#   2. The environment:
#        cp .env.example .env       # .env is gitignored
#        set -a; source .env; set +a
#        gradle assembleDebug
#
# They are baked into `BuildConfig.ADDRESSIQ_DEV_*` at build time and default to
# "" — so a published AAR carries nothing.
#
# EVERY value here is DEVELOPMENT-ONLY. The SDK honours them solely under
# AddressIQDeployment.DEVELOPMENT and THROWS on a staging or production build,
# even if set. A build-time value must never be able to point a shipped app at an
# arbitrary host.

# ── Hosts ────────────────────────────────────────────────────────────────────
# Default is a hardcoded http://10.0.2.2:4000. 10.0.2.2 is an EMULATOR alias for
# your machine's localhost — a PHYSICAL DEVICE cannot reach it. Use your LAN IP
# (`ipconfig getifaddr en0`), and make sure your backend binds 0.0.0.0 rather
# than 127.0.0.1.
#
# Plain HTTP to a LAN IP also needs cleartext permitted in the DEBUG manifest
# (android:usesCleartextTraffic="true", or a network_security_config scoped to
# that host). Debug only — never in a release.
ADDRESSIQ_DEV_API_URL=http://192.168.1.5:4000
ADDRESSIQ_DEV_INGEST_URL=http://192.168.1.5:4000
ADDRESSIQ_DEV_CDN_URL=http://192.168.1.5:5173

# ── Widget bundle ────────────────────────────────────────────────────────────
# Point the WebView at a widget you serve yourself, for live reload without
# re-vendoring:
#   cd ../addressiq-web && npx rollup -c && npx serve dist -p 5173
# A file:// path will NOT work — the emulator is a separate VM and cannot see
# your filesystem. It must be served over HTTP.
ADDRESSIQ_DEV_WIDGET_URL=

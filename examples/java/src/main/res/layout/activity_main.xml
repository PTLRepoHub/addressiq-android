<?xml version="1.0" encoding="utf-8"?>
<!-- Scroll container the Activity fills programmatically. fitsSystemWindows insets
     the content below the status/action bar (targetSdk 35+ forces edge-to-edge;
     without it the top controls render behind the bar and become untappable). -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp" />
</ScrollView>
